# ===== Configuração do Servidor =====
PORT=3000

# ===== MongoDB Atlas =====
# Cole aqui sua connection string do Atlas (Connect → Drivers → Node.js)
# Lembre de trocar <usuario>, <senha> e o nome do banco (ex: anitrack)
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxxx.mongodb.net/anitrack?retryWrites=true&w=majority

# ===== JWT (Autenticação) =====
# Use uma chave forte e secreta. NUNCA suba o .env real no GitHub!
JWT_SECRET=troque_por_uma_chave_secreta_bem_longa_e_aleatoria_123456
JWT_EXPIRES_IN=1h
